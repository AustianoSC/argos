# Logging
ARGOS_LOG_LEVEL=INFO       # DEBUG, INFO, WARNING, ERROR
ARGOS_LOG_FORMAT=text      # "json" for production, "text" for local dev

# Database
ARGOS_DATABASE_URL=postgresql+asyncpg://argos:argos_dev@localhost:5432/argos

# Redis
ARGOS_REDIS_URL=redis://localhost:6379

# LiteLLM proxy
ARGOS_LITELLM_BASE_URL=http://localhost:4000

# Upstream LLM provider (used by LiteLLM)
UPSTREAM_API_BASE=your-base-url-here
UPSTREAM_API_KEY=your-api-key-here

# Discord alerts (optional)
ARGOS_DISCORD_WEBHOOK_URL=
